# Copy to .env (Prisma CLI) and .env.local (Next.js runtime).
# Never commit either of those files.

# --- Database (Neon Postgres + pgvector) ---
# Get a free DB at https://neon.tech, then in the SQL editor run:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/returnguard?sslmode=require"

# --- Google Gemini ---
# Free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
# Optional model overrides. Defaults shown.
# Reasoning model: any Flash variant works. `gemini-flash-latest` always
# resolves to the current Flash (currently gemini-3-flash-preview).
# For stable production pinning use `gemini-2.5-flash`.
GEMINI_MODEL="gemini-flash-latest"
# Embedding model: gemini-embedding-001 defaults to 3072 dims; we truncate to
# 768 in lib/ai/embeddings.ts to match the Prisma schema's vector(768) column.
GEMINI_EMBEDDING_MODEL="gemini-embedding-001"

# --- Vercel Blob ---
# Auto-injected on Vercel; for local dev: `vercel env pull .env.local`
BLOB_READ_WRITE_TOKEN=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
