# Copy to .env (Prisma CLI) and .env.local (Next.js runtime).
# Never commit either of those files.

# --- Database (Neon Postgres + pgvector) ---
# Get a free DB at https://neon.tech, then in the SQL editor run:
#   CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/returnguard?sslmode=require"

# --- Google Gemini ---
# Free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# --- Vercel Blob ---
# Auto-injected on Vercel; for local dev: `vercel env pull .env.local`
BLOB_READ_WRITE_TOKEN=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
